# Secrets de K8s — nunca commitear valores reales.
# El shape se documenta en k8s/gke/apps/secret.example.yaml.
k8s/gke/apps/secret.yaml
k8s/gke/apps/secret.yaml.manual
k8s/gke/infra/rabbitmq-tls-secret.yaml.manual

# Archivos manuales con secretos (convención del proyecto)
*.manual

# TLS certs
k8s/gke/infra/tls/
*.pem
*.key

# Env files
.env
.env.*

# Python
__pycache__/
*.pyc

# Terraform
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.backup
infra/terraform.tfvars
infra/.terraform.lock.hcl
